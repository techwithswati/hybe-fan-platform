{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "HYBE Fan Platform - EKS HPA & Traffic Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🎤 HYBE Fan Platform - Live Drop Monitor",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 40 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Ticket Service Pods",
      "type": "stat",
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{deployment=\"ticket-service\", namespace=\"hybe-prod\"}",
          "legendFormat": "Ready Pods"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 40 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Merch Service Pods",
      "type": "stat",
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{deployment=\"merch-service\", namespace=\"hybe-prod\"}",
          "legendFormat": "Ready Pods"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "title": "Request Rate (req/s)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(nginx_ingress_controller_requests{namespace=\"hybe-prod\"}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "backgorund" },
      "title": "p95 Latency",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"hybe-prod\"}[1m])) by (le)) * 1000",
          "legendFormat": "p95 ms"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        },
          "overrides": [
            { "matcher": { "id": "byName", "options": "Max Replicas" }, "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10,10], "fill": "dash" } }] }
          ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 5,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },"tooltip": { "mode": "multi" } },
      "title": "HPA Pod Scaling - ticket & Merch Services (Watch this during load test!)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"hybe-prod\", horizontalpodautoscaler=\"ticket-service-hpa\"}",
          "legendFormat": "ticket-service (current)"
        },
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"hybe-prod\", horizontalpodautoscaler=\"merch-service-hpa\"}",
          "legendFormat": "merch-service (current)"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=\"hybe-prod\", horizontalpodautoscaler=\"ticket-service-hpa\"}",
          "legendFormat": "Max Replicas"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent", "max": 100 
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "id": 6,
      "title": "CPU Utilization by Service (HPA trigger at 60%)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg(rate(container_cpu_usage_seconds_total{namespace=\"hybe-prod\", container=\"ticket-service\"}[2m])) by (pod) * 100",
          "legendFormat": "ticket-service {{pod}}"
        },
        {
          "expr": "avg(rate(container_cpu_usage_seconds_total{namespace=\"hybe-prod\", container=\"merch-service\"}[2m])) by (pod) * 100",
          "legendFormat": "merch-service {{pod}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes" 
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "id": 7,
      "title": "Memory Usage by Service",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"hybe-prod\", container=\"ticket-service\"}) by (pod)",
          "legendFormat": "ticket {{pod}}"
        },
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"hybe-prod\", container=\"merch-service\"}) by (pod)",
          "legendFormat": "merch {{pod}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"  
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 21 },
      "id": 8,
      "title": "EKS Node Count (Cluster Autoscaler)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
          "legendFormat": "Ready Nodes"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"  
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 21 },
      "id": 9,
      "title": "RDS Connections",
      "type": "timeseries",
      "targets": [
        {
          "expr": "aws_rds_database_connections_average{dbinstance_identifier=~\"hybe.*\"}",
          "legendFormat": "{{dbinstance_identifier}}"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["hybe", "eks", "hpa", "kpop", "kubernetes"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Seoul",
  "title": "HYBE Fan Platform - Drop Monitor",
  "uid": "hybe-fan-platform-v1",
  "version": 1 
}
